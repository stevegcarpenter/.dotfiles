# Shared shell functions, sourced by the ~/.system loop in .zshrc

# Resolve the repo's primary branch (main vs master)
git_default_branch() {
  local b
  # ask the remote-tracking HEAD first; if this is stale or unset,
  # `git remote set-head origin -a` refreshes it from the remote
  b=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)
  if [[ -n $b ]]; then
    echo "${b#origin/}"
    return
  fi
  # fall back to whichever conventional branch exists locally
  if git show-ref --verify --quiet refs/heads/main; then
    echo main
  elif git show-ref --verify --quiet refs/heads/master; then
    echo master
  else
    git branch --show-current
  fi
}
